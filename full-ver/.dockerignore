# ==============================================================================
# .dockerignore - Docker Build Context Exclusions
# ==============================================================================
# Reduces build context size and improves build speed

# ==============================================================================
# Git
# ==============================================================================
.git
.gitignore
.github

# ==============================================================================
# Node.js
# ==============================================================================
node_modules
**/node_modules
.pnpm-store
.npm
.yarn

# ==============================================================================
# Build Outputs (rebuild in container)
# ==============================================================================
dist
build
.next
.turbo

# ==============================================================================
# IDE / Editor
# ==============================================================================
.vscode
.idea
*.swp
*.swo

# ==============================================================================
# Documentation
# ==============================================================================
docs
*.md
!README.md

# ==============================================================================
# Test / Coverage
# ==============================================================================
coverage
.nyc_output
*.lcov

# ==============================================================================
# Environment (handled separately)
# ==============================================================================
.env
.env.*
!.env.example

# ==============================================================================
# Logs
# ==============================================================================
logs
*.log

# ==============================================================================
# Claude Code / AI
# ==============================================================================
.claude
.auto-claude
prompts

# ==============================================================================
# Worktrees
# ==============================================================================
worktrees
.worktree-state
.worktree-context.yaml
.db-initialized
.setup-status
.devcontainer-startup.log

# ==============================================================================
# Design Assets (not needed in runtime)
# ==============================================================================
design

# ==============================================================================
# Specs (not needed in runtime)
# ==============================================================================
.specify
