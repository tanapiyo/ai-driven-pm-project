# ===========================================================================
# 環境変数テンプレート（docker-compose.worktree.yml 用）
# ===========================================================================
#
# このファイルは spawn.sh が自動生成する .env の構造を示すテンプレートです。
# 通常、手動でコピーする必要はありません。
#
# === 開発の始め方 ===
# 1. ./tools/worktree/spawn.sh implementer --issue <番号>
# 2. spawn.sh が .env を自動生成し、Docker スタックを起動します
#
# === このファイルを手動で使う場合 ===
# worktree を使わずにメインリポジトリから直接起動したい場合のみ:
#   cp .env.example .env
#   # ENDPOINT_NAME 等を適宜編集
#   ./tools/contract up
#
# === アプリの環境変数について ===
# DATABASE_URL, JWT_SECRET 等のアプリ変数は docker-compose.worktree.yml の
# environment: ブロックにデフォルト値が設定済みです。
# ローカル開発では変更不要です。
# ===========================================================================

# --- Docker Compose / Worktree 識別子 ---
# worktree ごとにコンテナ・ネットワークを分離するための変数。
# spawn.sh が自動設定します。
WORKTREE=main
COMPOSE_PROJECT_NAME=main
ENDPOINT_NAME=main.codama-ldh
CONTAINER_NAME=main
HOST_WORKSPACE_PATH=.

# --- ネットワーク分離 ---
# 並列 worktree でサブネットが衝突しないよう、spawn.sh が自動割当します。
INTERNAL_SUBNET=172.31.0.0/24
WEB_STATIC_IP=172.31.0.10
