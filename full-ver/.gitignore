# ==============================================================================
# .gitignore - Git Ignore Patterns
# ==============================================================================

# ==============================================================================
# OS Generated
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ==============================================================================
# DevContainer
# ==============================================================================
.devcontainer/.env.devcontainer
.devcontainer/.env.git-worktree
.devcontainer/.codex-auth.json

# ==============================================================================
# IDE / Editor
# ==============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ==============================================================================
# Node.js
# ==============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/
.npm
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ==============================================================================
# Build Outputs
# ==============================================================================
dist/
build/
out/
target/
bin/
obj/
*.exe
*.dll
*.so
*.dylib

# ==============================================================================
# Prisma (Generated Client)
# ==============================================================================
**/prisma/generated/

# TypeScript
*.tsbuildinfo
.tsbuildinfo
tsconfig.tsbuildinfo

# Next.js
.next/
.vercel/
next-env.d.ts

# Vite
.vite/

# ==============================================================================
# Cache
# ==============================================================================
.turbo/
.eslintcache
.prettiercache
.cache/
*.cache

# ==============================================================================
# Environment
# ==============================================================================
.env
.env.local
.env.*.local
.env.secrets
.envrc

# ==============================================================================
# Logs
# ==============================================================================
logs/
*.log

# ==============================================================================
# Coverage / Test
# ==============================================================================
coverage/
.nyc_output/
*.lcov
htmlcov/
.pytest_cache/
.tox/
.coverage
.coverage.*

# Playwright
test-results/
playwright-report/
playwright/.cache/
**/e2e/.auth/

# ==============================================================================
# Temporary
# ==============================================================================
tmp/
temp/
*.tmp
*.temp

# ==============================================================================
# Office / Binary Work Artifacts
# ==============================================================================
*.xlsx
*.xls
*.docx
*.doc
*.pptx
*.ppt

# ==============================================================================
# PII / Seed Data (local only)
# ==============================================================================

# ==============================================================================
# Secrets (NEVER commit)
# ==============================================================================
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ==============================================================================
# Claude Code
# ==============================================================================
.claude-handoff.md
.claude/*
!.claude/rules/
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/skills/
!.claude/settings.json
.claude/settings.local.json
.auto-claude/

# ==============================================================================
# Git Worktrees
# ==============================================================================
worktrees/
.worktree-state/
.worktree-context.yaml
.dev-ready
.db-initialized
.db-seeded-*
.git-main
.setup-status
.devcontainer-startup.log

# ==============================================================================
# Terraform
# ==============================================================================
# ローカル state ファイル（GCS バックエンドを使用するため不要）
infra/terraform/**/.terraform/
infra/terraform/**/*.tfstate
infra/terraform/**/*.tfstate.backup
# NOTE: .terraform.lock.hcl はコミット対象（プロバイダバージョン固定 + 再現性保証のため）

# シークレットを含む変数ファイル（.example のみコミット可）
infra/terraform/**/terraform.tfvars
infra/terraform/**/*.auto.tfvars

# プラン出力ファイル
infra/terraform/**/tfplan

# SA キーファイル（.gitkeep のみコミット可）
infra/terraform/credentials/*
!infra/terraform/credentials/.gitkeep
