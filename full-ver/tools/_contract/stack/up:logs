#!/usr/bin/env bash
# Contract: up:logs - View development environment logs
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
cd "${REPO_ROOT}"

# SAFETY CHECK: Prevent running from root repository
if [[ -d .git ]]; then
    echo "❌ ERROR: You are running 'contract up:logs' from the root repository."
    echo ""
    echo "   This command MUST be run from a worktree directory."
    echo ""
    exit 1
fi

# Load .env if exists, then derive WORKTREE from directory name
if [[ -f .env ]]; then
    # shellcheck source=/dev/null
    source .env
fi
WORKTREE="$(basename "$(pwd)")"
export WORKTREE

if docker compose version &>/dev/null; then
  COMPOSE_CMD="docker compose"
else
  COMPOSE_CMD="docker-compose"
fi

# Pass service name if provided, otherwise show all
SERVICE="${1:-}"

if [[ -n "${SERVICE}" ]]; then
  ${COMPOSE_CMD} -p "${WORKTREE}" -f docker-compose.worktree.yml logs -f "${SERVICE}"
else
  ${COMPOSE_CMD} -p "${WORKTREE}" -f docker-compose.worktree.yml logs -f
fi
